{
  "rewrites": [
    { "source": "/employee-portal", "destination": "/employee-portal/index.html" },
    { "source": "/((?!employee-portal/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
